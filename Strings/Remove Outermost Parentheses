void removeOuterParentheses(char *s, char *result) {
    int depth = 0;
    int j = 0;

    for (int i = 0; s[i] != '\0'; i++) {
        if (s[i] == '(') {
            if (depth > 0) {
                result[j++] = '(';
            }
            depth++;
        } else { // ')'
            depth--;
            if (depth > 0) {
                result[j++] = ')';
            }
        }
    }

    result[j] = '\0'; // end string
}
