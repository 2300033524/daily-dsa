def to_title_case(s):
    words = s.split()
    result = []

    for word in words:
        if word.isupper():
            result.append(word)
        else:
            result.append(word.capitalize())

    return " ".join(result)


T = int(input())
for _ in range(T):
    s = input()
    print(to_title_case(s))
